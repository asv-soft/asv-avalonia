{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "UnhandledExceptions": {
    "R3": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    },
    "TaskScheduler": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    }
  },
  "Plugins":
  {
    "PluginDataFolder": "plugins",
    "AdditionalFolderPerPlugin": [],
    "ApiPackageName": "Asv.Avalonia.Example.Api",
    "PluginAssemblyPrefix": "Asv.Avalonia.Example.Plugin."
  },
  "UserConfiguration":
  {
      "FilePath": "user_settings.json",
      "AutoSaveMs": 500
  },
  "SoloRun": 
  {
    "Mutex": "Asv.Avalonia.Example.Desktop",
    "ArgForward": true,
    "Pipe": "Asv.Avalonia.Example.Desktop"
  },
  "LogViewer": {
    "RollingSizeKb": 50,
    "Folder": "logs"
  }
          
}
