{
  "Logs": {
    "LogToConsole": true,
    "LogToFileOptions": {
      "Folder": "logs",
      "RollingSizeKb": 50
    },
    "Level": "Trace"
  },
  "UnhandledExceptions": {
    "R3": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    },
    "TaskScheduler": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    }
  }
          
}