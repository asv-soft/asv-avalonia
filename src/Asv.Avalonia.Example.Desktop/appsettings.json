{
  "Logging": {
    "LogLevel": {
      "Default": "Trace",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "UnhandledExceptions": {
    "IsEnabled": true,
    "R3": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    },
    "TaskScheduler": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    },
    "AppDomain": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    },
    "UiThread": {
      "PublishToShell": true,
      "PublishToLogger": true,
      "ForceApplicationCrash": false
    }
  },
  "Plugins": {
    "RelativeFolder": "plugins",
    "AdditionalFolderPerPlugin": [],
    "ApiPackageName": "Asv.Avalonia.Example.Api",
    "PluginAssemblyPrefix": "Asv.Avalonia.Example.Plugin."
  },
  "UserConfiguration": {
    "AutoSaveMs": 500
  },
  "SoloRun": {
    "Mutex": "Asv.Avalonia.Example.Desktop",
    "ArgForward": true,
    "Pipe": "Asv.Avalonia.Example.Desktop"
  },
  "Launcher": {
    "IsOptional": true
  },
  "LogToFile": {
    "RollingSizeKb": 51200,
    "Folder": "logs"
  },
  "LogViewer": {
    "Folder": "logs"
  },
  "UndoStore": {
    "Folder": "undo"
  }
}
