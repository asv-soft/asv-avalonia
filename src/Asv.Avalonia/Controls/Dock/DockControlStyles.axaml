<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:control="clr-namespace:Asv.Avalonia"
                    xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">
    <Design.PreviewWith>
        <Border Width="800" Height="1200" Margin="20" ClipToBounds="True">
            <control:DockControl>
                <control:DockControl.TabControlStripItemTemplate> 
                    <DataTemplate x:DataType="control:IPage"> 
                        <StackPanel Orientation="Horizontal" Spacing="4"> 
                            <avalonia:MaterialIcon Width="16" Height="16" Kind="{Binding Icon}"/> 
                            <TextBlock VerticalAlignment="Center" Text="{Binding Title}"/> 
                            <Button Theme="{StaticResource TransparentButton}" Command="{Binding TryClose}"  Padding="0"> 
                                <avalonia:MaterialIcon Kind="Close"/> 
                            </Button> 
                        </StackPanel> 
                    </DataTemplate>
                </control:DockControl.TabControlStripItemTemplate> 
                <control:HomePageViewModel />
                <control:SettingsPageViewModel />
            </control:DockControl>
        </Border>
    </Design.PreviewWith>
    
    <ControlTheme x:Key="{x:Type control:DockControl}" TargetType="control:DockControl">
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <control:DockTabControl x:Name="PART_MainTabControl"/>
                </Grid>
            </ControlTemplate>
        </Setter>
</ControlTheme>
</ResourceDictionary>
