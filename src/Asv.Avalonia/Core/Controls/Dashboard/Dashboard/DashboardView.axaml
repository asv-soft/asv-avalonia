<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonia="clr-namespace:Asv.Avalonia"
    mc:Ignorable="d"
    d:DesignWidth="400"
    d:DesignHeight="450"
    x:Class="Asv.Avalonia.DashboardView"
    x:DataType="avalonia:DashboardViewModel"
>
    <Design.DataContext>
        <avalonia:DashboardViewModel />
    </Design.DataContext>
    <UserControl.Styles>
        <Style Selector="Border.dashboard-density-drop-target.drag-over">
            <Setter
                Property="Background"
                Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"
            />
            <Setter
                Property="BorderBrush"
                Value="{DynamicResource SystemControlBackgroundAccentBrush}"
            />
        </Style>
    </UserControl.Styles>
    <StackPanel Spacing="4" Grid.IsSharedSizeScope="True">
        <Border
            x:Name="RegularDropTarget"
            Classes="dashboard-density-drop-target"
            MinHeight="28"
            BorderThickness="1"
            BorderBrush="Transparent"
            CornerRadius="4"
        >
            <ItemsControl ItemsSource="{Binding Regular}">
                <ItemsControl.ItemContainerTheme>
                    <ControlTheme TargetType="ContentPresenter">
                        <Setter Property="IsVisible" Value="{ReflectionBinding IsVisible}" />
                    </ControlTheme>
                </ItemsControl.ItemContainerTheme>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>
        <Border
            x:Name="InlineDropTarget"
            Classes="dashboard-density-drop-target"
            MinHeight="28"
            BorderThickness="1"
            BorderBrush="Transparent"
            CornerRadius="4"
        >
            <ItemsControl ItemsSource="{Binding Inline}">
                <ItemsControl.ItemContainerTheme>
                    <ControlTheme TargetType="ContentPresenter">
                        <Setter Property="IsVisible" Value="{ReflectionBinding IsVisible}" />
                    </ControlTheme>
                </ItemsControl.ItemContainerTheme>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>
    </StackPanel>
</UserControl>
