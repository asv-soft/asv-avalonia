<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonia="clr-namespace:Asv.Avalonia"
    xmlns:avalonia1="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    mc:Ignorable="d"
    d:DesignWidth="250"
    d:DesignHeight="80"
    x:Class="Asv.Avalonia.PropertyButtonView"
    x:DataType="avalonia:PropertyButtonViewModel"
>
    <Design.DataContext>
        <avalonia:PropertyButtonViewModel />
    </Design.DataContext>

    <Button
        Padding="4,4,0,4"
        HorizontalContentAlignment="Stretch"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Top"
        IsEnabled="{Binding !IsBusy}"
        Command="{Binding ExecuteCommand}"
    >
        <Panel>
            <avalonia:ExecuteIndicator
                IsExecuting="{Binding IsBusy}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
            />
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="PrefixIcon" Width="Auto" />
                    <ColumnDefinition SharedSizeGroup="PrefixName" Width="Auto" />
                    <ColumnDefinition SharedSizeGroup="PrefixStatus" Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition SharedSizeGroup="PostfixAction" Width="Auto" />
                </Grid.ColumnDefinitions>
                <avalonia1:MaterialIcon
                    Grid.Column="0"
                    Margin="4,0,0,0"
                    IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Kind="{Binding Icon}"
                    avalonia:AsvPallete.Color="{Binding IconColor}"
                />
                <TextBlock
                    Grid.Column="1"
                    MinWidth="20"
                    IsVisible="{Binding ShortHeader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    VerticalAlignment="Center"
                    Margin="4,0"
                    Classes="description"
                    Text="{Binding ShortHeader}"
                />
                <Panel Grid.Column="2">
                    <Ellipse
                        Opacity="0"
                        Margin="4,0,4,0"
                        Classes.fadeout="{Binding UpdatedFlag}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Width="5"
                        Height="5"
                        Fill="{DynamicResource AsvForegroundInfo3Brush}"
                    />
                    <avalonia1:MaterialIcon
                        ToolTip.Tip="{Binding ErrorMessage}"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Classes="blink"
                        Kind="{Binding ErrorIcon}"
                        Foreground="{DynamicResource AsvForegroundErrorBrush}"
                    />
                </Panel>
                <TextBlock
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    Margin="4,0"
                    Text="{Binding Header}"
                />
                <Border Background="Transparent" Grid.Column="0" Grid.ColumnSpan="2">
                    <ToolTip.Tip>
                        <StackPanel Spacing="8">
                            <TextBlock Classes="h1" Text="{Binding Header}" />
                            <TextBlock Classes="description" Text="{Binding Description}" />
                        </StackPanel>
                    </ToolTip.Tip>
                </Border>
            </Grid>
        </Panel>
    </Button>
</UserControl>
