<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonia="clr-namespace:Asv.Avalonia"
    xmlns:avalonia1="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    mc:Ignorable="d"
    d:DesignWidth="250"
    d:DesignHeight="120"
    x:Class="Asv.Avalonia.PropertyUnitView"
    x:DataType="avalonia:PropertyUnitViewModel"
>
    <Design.DataContext>
        <avalonia:PropertyUnitDesign />
    </Design.DataContext>

    <UserControl.Resources>
        <ControlTheme
            x:Key="PropertyMenuNodeTheme"
            TargetType="MenuItem"
            BasedOn="{StaticResource {x:Type MenuItem}}"
            x:DataType="avalonia:MenuNode"
        >
            <Setter
                Property="Icon"
                Value="{Binding Base.Icon, Converter={x:Static avalonia:MaterialIconConverter.Instance}}"
            />
            <Setter Property="Header" Value="{Binding Base.Header}" />
            <Setter Property="ItemsSource" Value="{Binding Items}" />
            <Setter Property="Command" Value="{Binding Base.Command}" />
            <Setter Property="CommandParameter" Value="{Binding Base.CommandParameter}" />
            <Setter Property="IsEnabled" Value="{Binding Base.IsEnabled}" />
            <Setter Property="IsVisible" Value="{Binding Base.IsVisible}" />
            <Setter Property="StaysOpenOnClick" Value="{Binding Base.StaysOpenOnClick}" />
            <Setter Property="InputGesture" Value="{Binding Base.HotKey}" />
            <Setter Property="IsChecked" Value="{Binding Base.IsChecked}" />
            <Setter Property="ToggleType" Value="{Binding Base.ToggleType}" />
            <Setter Property="GroupName" Value="{Binding Base.GroupName}" />
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBox#PART_TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="TextBox#PART_TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="TextBox#PART_TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="TextBox#PART_TextBox:error /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="TextBox#PART_TextBox:disabled /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.error">
            <Setter Property="BorderBrush" Value="{DynamicResource AsvForegroundErrorBrush}" />
        </Style>
        <Style Selector="Border.property-border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.property-border:pointerover">
            <Setter Property="Background" Value="{DynamicResource TextControlBackgroundPointerOver}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushPointerOver}" />
        </Style>
        <Style Selector="Border.property-border.editing">
            <Setter Property="Background" Value="{DynamicResource TextControlBackgroundFocused}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushFocused}" />
        </Style>
        <Style Selector="Border.property-border.error">
            <Setter Property="BorderBrush" Value="{DynamicResource AsvForegroundErrorBrush}" />
        </Style>
        <Style Selector="DataValidationErrors">
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <ContentPresenter
                            Name="PART_ContentPresenter"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Content="{TemplateBinding Content}"
                            Padding="{TemplateBinding Padding}"
                        />
                        <ContentControl
                            HorizontalAlignment="Right"
                            Margin="0,0,4,0"
                            ContentTemplate="{TemplateBinding ErrorTemplate}"
                            DataContext="{TemplateBinding Owner}"
                            Content="{Binding (DataValidationErrors.Errors)}"
                            IsVisible="{Binding (DataValidationErrors.HasErrors)}"
                        />
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Setter Property="ErrorTemplate">
                <DataTemplate x:DataType="{x:Type x:Object}">
                    <Canvas Width="14" Height="14" Margin="4 0 1 0" Background="Transparent">
                        <Canvas.Styles>
                            <Style Selector="ToolTip">
                                <Setter
                                    Property="Background"
                                    Value="{DynamicResource AsvForegroundErrorBrush}"
                                />
                                <Setter
                                    Property="BorderBrush"
                                    Value="{DynamicResource AsvForegroundErrorBrush}"
                                />
                            </Style>
                        </Canvas.Styles>
                        <ToolTip.Tip>
                            <ItemsControl ItemsSource="{Binding}" />
                        </ToolTip.Tip>
                        <Path
                            Data="M14,7 A7,7 0 0,0 0,7 M0,7 A7,7 0 1,0 14,7 M7,3l0,5 M7,9l0,2"
                            Stroke="{DynamicResource AsvForegroundErrorBrush}"
                            StrokeThickness="2"
                        />
                    </Canvas>
                </DataTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Border
        Classes="property-border"
        Classes.error="{Binding (DataValidationErrors.HasErrors), ElementName=PART_TextBox}"
        Classes.editing="{Binding IsInEditMode}"
        VerticalAlignment="Top"
        HorizontalAlignment="Stretch"
        BorderThickness="0.5"
        CornerRadius="4"
        Padding="2,0"
    >
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition SharedSizeGroup="PrefixIcon" Width="Auto" />
                <ColumnDefinition SharedSizeGroup="PrefixName" Width="Auto" />
                <ColumnDefinition SharedSizeGroup="PrefixStatus" Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition SharedSizeGroup="PostfixUnits" Width="Auto" />
                <ColumnDefinition SharedSizeGroup="PostfixAction" Width="Auto" />
            </Grid.ColumnDefinitions>
            <avalonia1:MaterialIcon
                Grid.Column="0"
                Margin="4,0,0,0"
                IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                avalonia:AsvPallete.Color="{Binding IconColor}"
                Width="16"
                Height="16"
                Foreground="{DynamicResource TextControlForegroundDisabled}"
                Kind="{Binding Icon}"
            />
            <TextBlock
                Grid.Column="1"
                MinWidth="20"
                IsVisible="{Binding ShortHeader, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                VerticalAlignment="Center"
                Margin="4,0"
                Classes="description"
                Text="{Binding ShortHeader}"
            />
            <Panel Grid.Column="2">
                <Ellipse
                    Opacity="0"
                    Margin="4,0,4,0"
                    Classes.fadeout="{Binding UpdatedFlag}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="5"
                    Height="5"
                    Fill="{DynamicResource AsvForegroundInfo3Brush}"
                />
                <avalonia1:MaterialIcon
                    Classes="blink"
                    ToolTip.Tip="{Binding ErrorMessage}"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Kind="{Binding ErrorIcon}"
                    Foreground="{DynamicResource AsvForegroundErrorBrush}"
                />
            </Panel>

            <TextBox
                x:Name="PART_TextBox"
                GotFocus="PART_TextBox_OnGotFocus"
                LostFocus="PART_TextBox_OnLostFocus"
                Grid.Column="3"
                IsEnabled="{Binding !IsBusy}"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Padding="4"
                Text="{Binding Text.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            >
                <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding ApplyFromUserCommand}" />
                </TextBox.KeyBindings>
                <ToolTip.Tip>
                    <StackPanel Spacing="8">
                        <TextBlock Classes="h1" Text="{Binding Header}" />
                        <TextBlock Classes="description" Text="{Binding Description}" />
                    </StackPanel>
                </ToolTip.Tip>
            </TextBox>

            <Button
                Grid.Column="5"
                Padding="4"
                Theme="{StaticResource TransparentButton}"
                IsVisible="{Binding MenuView, Converter={x:Static ObjectConverters.IsNotNull}}"
            >
                <Button.Flyout>
                    <MenuFlyout ItemsSource="{Binding MenuView.Items}">
                        <MenuFlyout.ItemContainerTheme>
                            <StaticResource ResourceKey="PropertyMenuNodeTheme" />
                        </MenuFlyout.ItemContainerTheme>
                    </MenuFlyout>
                </Button.Flyout>
                <avalonia1:MaterialIcon Kind="DotsVertical" />
            </Button>

            <Panel Grid.Column="4">
                <Button Padding="4,2" IsTabStop="False" Theme="{DynamicResource TransparentButton}">
                    <Button.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.Or}">
                            <Binding Path="IsSync" />
                            <Binding Path="IsBusy" />
                            <Binding Path="Text.HasErrors" />
                        </MultiBinding>
                    </Button.IsVisible>
                    <Button.Flyout>
                        <MenuFlyout ItemsSource="{Binding Unit.AvailableUnits.Values}">
                            <MenuFlyout.ItemContainerTheme>
                                <ControlTheme
                                    TargetType="MenuItem"
                                    BasedOn="{StaticResource {x:Type MenuItem}}"
                                    x:DataType="avalonia:IUnitItem"
                                >
                                    <Setter Property="Header" Value="{Binding Name}" />
                                    <Setter
                                        Property="Command"
                                        Value="{ReflectionBinding DataContext.ChangeUnitCommand, ElementName=PART_TextBox}"
                                    />
                                    <Setter Property="CommandParameter" Value="{Binding }" />
                                </ControlTheme>
                            </MenuFlyout.ItemContainerTheme>
                        </MenuFlyout>
                    </Button.Flyout>
                    <TextBlock
                        Classes="description"
                        VerticalAlignment="Center"
                        Text="{Binding Unit.CurrentUnitItem.Value.Symbol}"
                    />
                </Button>
                <Button
                    Padding="4,2"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Right"
                    Theme="{DynamicResource TransparentButton}"
                    Command="{Binding ApplyFromUserCommand}"
                >
                    <Button.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsSync" />
                            <Binding Path="!IsBusy" />
                            <Binding Path="!Text.HasErrors" />
                        </MultiBinding>
                    </Button.IsVisible>
                    <avalonia1:MaterialIcon
                        Width="20"
                        Height="20"
                        Kind="Pencil"
                        Foreground="{DynamicResource AsvForegroundSuccessBrush}"
                    />
                </Button>
            </Panel>

            <ProgressBar
                Grid.Column="0"
                Grid.ColumnSpan="5"
                IsVisible="{Binding IsBusy}"
                Background="Transparent"
                Height="20"
                Opacity="0.5"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                Minimum="0"
                Maximum="1"
                IsIndeterminate="True"
            />
        </Grid>
    </Border>
</UserControl>
