<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonia="clr-namespace:Asv.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Asv.Avalonia.SerialPortView">
    <Design.DataContext>
        <avalonia:SerialPortViewModel/>
    </Design.DataContext>
    <Panel>
        <StackPanel   Spacing="10" Margin="10">
            <TextBlock Text="Port title" />
            <TextBox Text="" />
            <TextBlock Text="Port Name" />
            <ComboBox Margin="0,0" SelectedItem="" />
            <TextBlock Text="Baud Rate" />
            <ComboBox SelectedItem=""
                      ItemsSource="" />
            <TextBlock Text="Packet loss chance"  />
            <TextBox Text="" />
        </StackPanel>
    </Panel>
</UserControl>
