<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:example="clr-namespace:Asv.Avalonia.Example.Plugin.PluginExample"
    mc:Ignorable="d"
    d:DesignWidth="800"
    d:DesignHeight="450"
    x:Class="Asv.Avalonia.Example.Plugin.PluginExample.ExamplePageView"
    x:DataType="example:ExamplePageViewModel"
>
    <Design.DataContext>
        <example:ExamplePageViewModel/>
    </Design.DataContext>
    <StackPanel>
        <Button HotKey="Ctrl+Z" Command="{Binding UndoHistory.Undo}" Content="Undo"/>
        <Button Command="{Binding UndoHistory.Redo}" Content="Redo"/>
        <TextBox Width="200" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Text1.Value}"/>
    </StackPanel>
    
    
    
</UserControl
>
