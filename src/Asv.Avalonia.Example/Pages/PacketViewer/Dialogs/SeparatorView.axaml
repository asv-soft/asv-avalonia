<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:example="clr-namespace:Asv.Avalonia.Example"
             mc:Ignorable="d" Width="400" Height="200"
             x:CompileBindings="True"
             x:DataType="example:SeparatorViewModel"
             x:Class="Asv.Avalonia.Example.SeparatorView">
    <Design.DataContext>
        <example:SeparatorViewModel />
    </Design.DataContext>
    <Panel>
        <StackPanel Spacing="10" Margin="10">
            <TextBlock Text="Select separator:" FontSize="16"/>
            <RadioButton Content=";"
                         IsChecked="{CompiledBinding IsSemicolon.Value, Mode=TwoWay}" />
            <RadioButton Content=","
                         IsChecked="{CompiledBinding IsComa.Value, Mode=TwoWay}" />
            <RadioButton Content="TAB"
                         IsChecked="{CompiledBinding IsTab.Value, Mode=TwoWay}" />
        </StackPanel>
    </Panel>
</UserControl>