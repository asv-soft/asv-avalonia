<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:example="clr-namespace:Asv.Avalonia.Example"
    mc:Ignorable="d"
    d:DesignWidth="1200"
    d:DesignHeight="450"
    x:Class="Asv.Avalonia.Example.PropertyEditorPageView"
    x:DataType="example:PropertyEditorPageViewModel"
>
    <Design.DataContext>
        <example:PropertyEditorPageViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBlock.value-label">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.value-text">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="16" ColumnDefinitions="340,*,340">
        <Grid Grid.Column="0" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock Classes="h1" Margin="0,0,0,12" Text="PropertyEditor" />
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding PropertyEditor}" />
            </ScrollViewer>
        </Grid>

        <ScrollViewer Grid.Column="1" Margin="24,0" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="520" VerticalAlignment="Center" Spacing="12">
                <TextBlock Classes="h1" Text="Model values" />

                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="description value-label" Text="Display name" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Classes="value-text" Text="{Binding DisplayName.Value}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="description value-label" Text="Operation profile" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="value-text"
                        Text="{Binding OperationProfile.Value.Header}"
                    />

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="description value-label" Text="Run check count" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Classes="value-text"
                        Text="{Binding ActionButtonClickCount}"
                    />

                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="description value-label" Text="GeoPoint" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="value-text" Text="{Binding GeoPoint.Value}" />
                </Grid>

                <TextBlock Classes="h2" Margin="0,8,0,0" Text="Units" />
                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="description value-label" Text="Altitude V2 model" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Classes="value-text"
                        Text="{Binding AltitudeUnitValue.Value}"
                    />

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="description value-label" Text="Throttle V2 model" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Classes="value-text"
                        Text="{Binding ThrottleUnitValue.Value}"
                    />

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="description value-label" Text="Time model" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="value-text" Text="{Binding Time.Value}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="description value-label" Text="Throttle model" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="value-text" Text="{Binding Throttle.Value}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="description value-label" Text="Altitude model" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="value-text" Text="{Binding Altitude.Value}" />
                </Grid>

                <TextBlock Classes="h2" Margin="0,8,0,0" Text="Position" />
                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="description value-label" Text="Latitude model" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Classes="value-text" Text="{Binding Latitude.Value}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="description value-label" Text="Longitude model" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Classes="value-text" Text="{Binding Longitude.Value}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="description value-label" Text="Altitude model" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="value-text" Text="{Binding Altitude.Value}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="2" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <TextBlock Classes="h1" Margin="0,0,0,12" Text="PropertyEditor copy" />
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding PropertyEditorCopy}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
