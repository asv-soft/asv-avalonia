<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:geoMap="clr-namespace:Asv.Avalonia.GeoMap"
    mc:Ignorable="d"
    d:DesignWidth="980"
    d:DesignHeight="640"
    x:Class="Asv.Avalonia.GeoMap.SettingsGeoMapView"
    x:DataType="geoMap:SettingsGeoMapViewModel"
>
    <Design.DataContext>
        <geoMap:SettingsGeoMapViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <ContentControl Grid.Row="0" Content="{Binding Editor}" />

        <Grid Grid.Row="1" MinHeight="280" Margin="16,0,16,16" RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Margin="0,0,0,8" Spacing="4">
                <TextBlock Classes="h2" Text="{Binding MapPreviewHeader}" />
                <TextBlock
                    Classes="description"
                    Text="{Binding MapPreviewDescription}"
                    TextWrapping="Wrap"
                />
            </StackPanel>
            <Border
                Grid.Row="1"
                ClipToBounds="True"
                BorderBrush="{DynamicResource ButtonBackground}"
                BorderThickness="1"
            >
                <geoMap:MapView DataContext="{Binding MapPreview}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
