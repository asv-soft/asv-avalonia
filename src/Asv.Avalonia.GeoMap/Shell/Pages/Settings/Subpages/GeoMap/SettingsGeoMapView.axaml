<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:geoMap="clr-namespace:Asv.Avalonia.GeoMap"
    mc:Ignorable="d"
    d:DesignWidth="980"
    d:DesignHeight="640"
    x:Class="Asv.Avalonia.GeoMap.SettingsGeoMapView"
    x:DataType="geoMap:SettingsGeoMapViewModel"
>
    <Design.DataContext>
        <geoMap:SettingsGeoMapViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <ContentControl Grid.Row="0" Content="{Binding Editor}" />

        <Grid Grid.Row="1" MinHeight="280" Margin="16,0,16,16" RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Margin="0,0,0,8" Spacing="4">
                <TextBlock Classes="h2" Text="{Binding MapPreviewHeader}" />
                <TextBlock
                    Classes="description"
                    Text="{Binding MapPreviewDescription}"
                    TextWrapping="Wrap"
                />
            </StackPanel>
            <Border
                Grid.Row="1"
                ClipToBounds="True"
                BorderBrush="{DynamicResource ButtonBackground}"
                BorderThickness="1"
            >
                <Panel>
                    <geoMap:MapView x:Name="PART_Map" DataContext="{Binding MapPreview}" />
                    <geoMap:MapCompass
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="8"
                        GestureSurface="{Binding #PART_Map}"
                        Rotation="{Binding MapPreview.Rotation.Value}"
                    />
                    <geoMap:MapRuler
                        x:Name="PART_Ruler"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="8"
                        Anchors="{Binding MapPreview.Anchors}"
                        UnitService="{Binding UnitService}"
                        LoggerFactory="{Binding LoggerFactory}"
                        TargetMap="{Binding #PART_Map}"
                    />
                    <Border
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,12,0,0"
                        Padding="12,6"
                        CornerRadius="4"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1"
                        IsHitTestVisible="False"
                        IsVisible="{Binding #PART_Ruler.PromptText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    >
                        <TextBlock
                            Text="{Binding #PART_Ruler.PromptText}"
                            Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                        />
                    </Border>
                </Panel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
