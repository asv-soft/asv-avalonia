<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonia="clr-namespace:Asv.Avalonia;assembly=Asv.Avalonia"
    xmlns:map="clr-namespace:Asv.Avalonia.GeoMap"
    xmlns:avalonia1="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    mc:Ignorable="d"
    d:DesignWidth="250"
    d:DesignHeight="160"
    x:Class="Asv.Avalonia.GeoMap.PropertyGeoPointView"
    x:DataType="map:PropertyGeoPointViewModel"
>
    <Design.DataContext>
        <map:PropertyGeoPointDesign />
    </Design.DataContext>

    <ToolTip.Tip>
        <StackPanel
            Spacing="8"
            IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
        >
            <TextBlock Classes="h1" Text="{Binding Header}" />
            <TextBlock Classes="description" Text="{Binding Description}" />
        </StackPanel>
    </ToolTip.Tip>

    <StackPanel Spacing="4">
        <DockPanel Margin="4,4,4,0">
            <Button
                Padding="4"
                DockPanel.Dock="Right"
                Theme="{StaticResource TransparentButton}"
                IsVisible="{Binding MenuView, Converter={x:Static ObjectConverters.IsNotNull}}"
            >
                <avalonia1:MaterialIcon Kind="DotsHorizontal" />
            </Button>
            <Button
                Padding="4"
                DockPanel.Dock="Right"
                Theme="{StaticResource TransparentButton}"
                Command="{Binding OpenGeoPointDialogCommand}"
                IsVisible="{Binding CanOpenGeoPointDialog}"
            >
                <avalonia1:MaterialIcon Kind="MapMarkerRadius" />
            </Button>
            <TextBlock
                Margin="10,2"
                IsVisible="{Binding Header, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Text="{Binding Header}"
            />
        </DockPanel>

        <ContentControl Content="{Binding Latitude}" />
        <ContentControl Content="{Binding Longitude}" />
        <ContentControl Content="{Binding Altitude}" />
    </StackPanel>
</UserControl>
